# Environment variables for LLM evaluation framework
# Copy this file to .env and fill in your values

# OpenAI API key (required for DeepEval LLM-based metrics)
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic API key (optional, for Claude-based evaluations)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Application environment: development, test, production
APP_ENV=development

# DeepEval Confident AI key (optional, for dashboard reporting)
DEEPEVAL_API_KEY=your-deepeval-api-key-here
